model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["DirectQuery to AS - Oncology_Gold_Model_N"]

annotation PBI_ProTooling = ["DevMode"]

ref table Gold_Oncology_Dashboard_Source
ref table Gold_Medicine_Metrics_Source
ref table Calendar
ref table 'Calendar new'

ref cultureInfo en-US

